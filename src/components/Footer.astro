---
const currentYear = new Date().getFullYear();
---
<footer class="bg-gray-900 text-white pt-16 pb-8">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-12 mb-12">
      <div class="col-span-1 md:col-span-2">
        <a href="/" class="text-2xl font-bold flex items-center gap-2 mb-4">
          <span class="text-white">GreenTree<span class="text-primary-500">Care</span></span>
        </a>
        <p class="text-gray-400 max-w-sm mb-6 leading-relaxed">
          Professional, safe, and reliable tree services for residential and commercial properties. Your trees are our business.
        </p>
        <div class="flex space-x-4">
           <!-- Social Icons Placeholder -->
           <a href="#" class="text-gray-400 hover:text-white transition-colors">
              <span class="sr-only">Facebook</span>
              <svg class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24"><path fill-rule="evenodd" d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z" clip-rule="evenodd" /></svg>
           </a>
        </div>
      </div>
      <div>
        <h3 class="text-lg font-semibold mb-4 text-white">Quick Links</h3>
        <ul class="space-y-4 text-gray-300">
          <li><a href="/" class="text-base hover:text-white transition-colors block py-1">Home</a></li>
          <li><a href="/emergency-removal" class="text-base hover:text-white transition-colors block py-1">Emergency Removal</a></li>
          <li><a href="/blog" class="text-base hover:text-white transition-colors block py-1">Blog</a></li>
          <li><a href="/contact-us" class="text-base hover:text-white transition-colors block py-1">Contact Us</a></li>
        </ul>
      </div>
      <div>
        <h3 class="text-lg font-semibold mb-4 text-white">Contact Info</h3>
        <ul class="space-y-5 text-gray-300">
          <li class="flex items-start text-base">
            <svg class="h-6 w-6 mr-4 text-primary-500 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
            <div>123 Arborist Lane<br/>Treeville, VA 22030</div>
          </li>
          <li class="flex items-center text-base">
            <svg class="h-6 w-6 mr-4 text-primary-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
            <a href="tel:5551234567" class="hover:text-white transition-colors">(555) 123-4567</a>
          </li>
          <li class="flex items-center text-base">
            <svg class="h-6 w-6 mr-4 text-primary-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2 2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
            <a href="mailto:info@greentreecare.com" class="hover:text-white transition-colors">info@greentreecare.com</a>
          </li>
        </ul>
      </div>
    </div>
    <div class="border-t border-gray-800 pt-8 flex flex-col md:flex-row justify-between items-center text-gray-400 text-sm">
      <p>&copy; {currentYear} GreenTree Care. All rights reserved.</p>
      <div class="mt-4 md:mt-0 space-x-4">
        <a href="#" class="hover:text-white transition-colors">Privacy Policy</a>
        <a href="#" class="hover:text-white transition-colors">Terms of Service</a>
      </div>
    </div>
  </div>
</footer>
