---
// src/components/Header.astro
const links = [
  { name: 'Home', href: '/' },
  { name: 'Emergency Removal', href: '/emergency-removal' },
  { name: 'Blog', href: '/blog' },
  { name: 'Contact Us', href: '/contact-us' },
];
---
<header class="sticky top-0 z-50 bg-white/90 backdrop-blur-md border-b border-gray-100 transition-all duration-300">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center h-20">
      <div class="flex-shrink-0 flex items-center">
        <a href="/" class="text-2xl font-bold text-primary-700 flex items-center gap-2 group">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-primary-600 group-hover:rotate-12 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
             <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 15l7-7 7 7" />
          </svg>
          <span class="tracking-tight">GreenTree<span class="text-green-600">Care</span></span>
        </a>
      </div>
      
      <nav class="hidden md:flex space-x-8">
        {links.map((link) => (
          <a href={link.href} class="text-gray-700 hover:text-primary-600 text-lg font-medium transition-colors">
            {link.name}
          </a>
        ))}
      </nav>

      <div class="hidden md:flex">
        <a href="/contact-us" class="bg-primary-600 hover:bg-primary-700 text-white px-8 py-3 rounded-full text-lg font-bold transition-all shadow hover:shadow-lg hover:-translate-y-0.5 transform">
          Get a Quote
        </a>
      </div>
      
      <!-- Mobile menu button -->
      <div class="md:hidden flex items-center">
        <button id="mobile-menu-btn" aria-label="Open mobile menu" class="text-gray-600 hover:text-gray-900 focus:outline-none">
          <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
        </button>
      </div>
    </div>
  </div>
  
  <!-- Mobile Menu -->
  <div id="mobile-menu" class="hidden md:hidden bg-white border-b border-gray-100 absolute w-full left-0 top-20 shadow-lg">
    <div class="px-4 pt-4 pb-8 space-y-2">
      {links.map((link) => (
        <a href={link.href} class="block px-4 py-4 rounded-lg text-lg font-medium text-gray-800 hover:text-primary-600 hover:bg-primary-50 transition-colors">
          {link.name}
        </a>
      ))}
      <a href="/contact-us" class="block w-full text-center mt-6 bg-primary-600 hover:bg-primary-700 text-white px-4 py-4 rounded-xl font-bold text-lg shadow-md transition-colors">Get a Quote</a>
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  
  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
</script>
