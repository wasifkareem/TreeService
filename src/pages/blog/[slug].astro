---
import Layout from '../../layouts/Layout.astro';
import { client, urlFor } from '../../sanity/client';
import { PortableText } from 'astro-portabletext';
import SanityImage from '../../components/SanityImage.astro';

export async function getStaticPaths() {
  const posts = await client.fetch(`*[_type == "blog"]{ slug }`);
  
  return posts.map((post: any) => ({
    params: { slug: post.slug.current },
  }));
}

const { slug } = Astro.params;
const post = await client.fetch(`*[_type == "blog" && slug.current == $slug][0]{
  title,
  publishedAt,
  mainImage,
  body,
  excerpt,
  author,
  categories
}`, { slug });

if (!post) {
  return Astro.redirect('/404');
}

// Format date
const formattedDate = post.publishedAt 
  ? new Date(post.publishedAt).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' }) 
  : '';

// Estimated reading time from body
function estimateReadingTime(body: any[]): number {
  if (!body) return 1;
  let wordCount = 0;
  for (const block of body) {
    if (block._type === 'block' && block.children) {
      for (const child of block.children) {
        if (child.text) wordCount += child.text.split(/\s+/).length;
      }
    }
  }
  return Math.max(1, Math.ceil(wordCount / 200));
}
const readingTime = estimateReadingTime(post.body);
---

<Layout title={post.title} description={post.excerpt || `Read ${post.title} on GreenTree Care blog.`}>
  <article class="blog-article">
    <!-- Hero Section -->
    {post.mainImage ? (
      <header class="blog-hero blog-hero--with-image">
        <img
          src={urlFor(post.mainImage).width(1920).height(900).quality(85).url()}
          alt={post.mainImage.alt || post.title}
          class="blog-hero__image"
        />
        <div class="blog-hero__overlay"></div>
        <div class="blog-hero__content">
          {post.categories && post.categories.length > 0 && (
            <div class="blog-hero__categories">
              {post.categories.map((cat: string) => (
                <span class="blog-category-tag">{cat}</span>
              ))}
            </div>
          )}
          <h1 class="blog-hero__title">{post.title}</h1>
          <div class="blog-hero__meta">
            <div class="blog-meta-item">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
              <span>{formattedDate}</span>
            </div>
            {post.author && (
              <div class="blog-meta-item">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                <span>{post.author}</span>
              </div>
            )}
            <div class="blog-meta-item">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
              <span>{readingTime} min read</span>
            </div>
          </div>
        </div>
      </header>
    ) : (
      <header class="blog-hero blog-hero--no-image">
        <div class="blog-hero__content">
          {post.categories && post.categories.length > 0 && (
            <div class="blog-hero__categories">
              {post.categories.map((cat: string) => (
                <span class="blog-category-tag">{cat}</span>
              ))}
            </div>
          )}
          <h1 class="blog-hero__title">{post.title}</h1>
          <div class="blog-hero__meta">
            <div class="blog-meta-item">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
              <span>{formattedDate}</span>
            </div>
            {post.author && (
              <div class="blog-meta-item">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                <span>{post.author}</span>
              </div>
            )}
            <div class="blog-meta-item">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
              <span>{readingTime} min read</span>
            </div>
          </div>
        </div>
      </header>
    )}

    <!-- Blog Body -->
    <div class="blog-body">
      <div class="blog-body__inner prose prose-lg prose-green">
        <PortableText 
          value={post.body || []} 
          components={{
            type: {
              image: SanityImage
            }
          }}
        />
      </div>
    </div>

    <!-- Back to Blog -->
    <div class="blog-back">
      <a href="/blog" class="blog-back__link">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
        Back to All Articles
      </a>
    </div>
  </article>
</Layout>

<style is:global>
  /* ==========================================
     BLOG HERO
     ========================================== */
  .blog-hero {
    position: relative;
    display: flex;
    align-items: flex-end;
    overflow: hidden;
  }

  .blog-hero--with-image {
    min-height: 50vh;
    max-height: 70vh;
  }

  .blog-hero--no-image {
    background: linear-gradient(135deg, #14532d 0%, #166534 40%, #15803d 100%);
    padding: 10rem 1rem 4rem;
  }

  .blog-hero__image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .blog-hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(0, 0, 0, 0.85) 0%,
      rgba(0, 0, 0, 0.4) 50%,
      rgba(0, 0, 0, 0.1) 100%
    );
  }

  .blog-hero__content {
    position: relative;
    width: 100%;
    max-width: 52rem;
    margin: 0 auto;
    padding: 3rem 1.5rem;
    z-index: 10;
  }

  .blog-hero__categories {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1rem;
  }

  .blog-category-tag {
    display: inline-block;
    background: rgba(74, 222, 128, 0.2);
    color: #4ade80;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    padding: 0.3rem 0.8rem;
    border-radius: 9999px;
    border: 1px solid rgba(74, 222, 128, 0.3);
    backdrop-filter: blur(8px);
  }

  .blog-hero__title {
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 800;
    color: #ffffff;
    line-height: 1.15;
    margin-bottom: 1.25rem;
    letter-spacing: -0.02em;
  }

  .blog-hero__meta {
    display: flex;
    flex-wrap: wrap;
    gap: 1.25rem;
    align-items: center;
  }

  .blog-meta-item {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    color: rgba(255, 255, 255, 0.75);
    font-size: 0.875rem;
    font-weight: 500;
  }

  .blog-meta-item svg {
    opacity: 0.6;
  }

  /* ==========================================
     BLOG BODY — RICH TEXT RENDERING
     ========================================== */
  .blog-body {
    background-color: #ffffff;
    padding: 4rem 1.5rem 2rem;
  }

  .blog-body__inner {
    max-width: 48rem;
    margin: 0 auto;
  }

  /* --- Headings --- */
  .blog-body__inner h2 {
    color: #111827;
    font-weight: 800;
    font-size: 1.75rem;
    margin-top: 3rem;
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid #dcfce7;
    letter-spacing: -0.01em;
  }

  .blog-body__inner h3 {
    color: #1f2937;
    font-weight: 700;
    font-size: 1.35rem;
    margin-top: 2.25rem;
    margin-bottom: 0.75rem;
  }

  .blog-body__inner h4 {
    color: #374151;
    font-weight: 600;
    font-size: 1.15rem;
    margin-top: 2rem;
    margin-bottom: 0.5rem;
  }

  /* --- Paragraphs --- */
  .blog-body__inner p {
    color: #374151;
    line-height: 1.85;
    margin-bottom: 1.5rem;
    font-size: 1.1rem;
  }

  /* --- Links --- */
  .blog-body__inner a {
    color: #16a34a;
    text-decoration: underline;
    text-decoration-color: rgba(22, 163, 74, 0.3);
    text-underline-offset: 3px;
    font-weight: 500;
    transition: all 0.2s ease;
  }

  .blog-body__inner a:hover {
    color: #15803d;
    text-decoration-color: #15803d;
  }

  /* --- Blockquotes --- */
  .blog-body__inner blockquote {
    border-left: 4px solid #16a34a;
    background: linear-gradient(135deg, #f0fdf4, #dcfce7);
    padding: 1.5rem 1.75rem;
    margin: 2rem 0;
    border-radius: 0 0.75rem 0.75rem 0;
    position: relative;
  }

  .blog-body__inner blockquote::before {
    content: '"';
    position: absolute;
    top: -0.5rem;
    left: 1rem;
    font-size: 4rem;
    line-height: 1;
    color: rgba(22, 163, 74, 0.15);
    font-family: Georgia, serif;
    font-weight: 700;
  }

  .blog-body__inner blockquote p {
    color: #166534;
    font-style: italic;
    font-size: 1.1rem;
    margin-bottom: 0;
    position: relative;
  }

  /* --- Lists --- */
  .blog-body__inner ul {
    list-style: none;
    padding-left: 0;
    margin: 1.5rem 0;
  }

  .blog-body__inner ul li {
    color: #374151;
    line-height: 1.8;
    padding-left: 1.75rem;
    position: relative;
    margin-bottom: 0.6rem;
    font-size: 1.1rem;
  }

  .blog-body__inner ul li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.65rem;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: linear-gradient(135deg, #22c55e, #16a34a);
    box-shadow: 0 0 0 3px rgba(34, 197, 94, 0.15);
  }

  .blog-body__inner ol {
    padding-left: 1.5rem;
    margin: 1.5rem 0;
    counter-reset: list-counter;
  }

  .blog-body__inner ol li {
    color: #374151;
    line-height: 1.8;
    margin-bottom: 0.6rem;
    font-size: 1.1rem;
    counter-increment: list-counter;
    list-style: none;
    padding-left: 1.5rem;
    position: relative;
  }

  .blog-body__inner ol li::before {
    content: counter(list-counter);
    position: absolute;
    left: 0;
    top: 0.15rem;
    width: 1.5rem;
    height: 1.5rem;
    background: linear-gradient(135deg, #22c55e, #16a34a);
    color: #fff;
    font-size: 0.75rem;
    font-weight: 700;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* --- Code (inline) --- */
  .blog-body__inner code {
    background: #f3f4f6;
    color: #166534;
    padding: 0.15rem 0.45rem;
    border-radius: 0.3rem;
    font-size: 0.9em;
    font-weight: 500;
    border: 1px solid #e5e7eb;
  }

  /* --- Images (Portable Text image blocks) --- */
  .blog-body__inner img {
    width: 100%;
    border-radius: 1rem;
    margin: 2rem 0;
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.08);
    border: 1px solid #e5e7eb;
  }

  .blog-body__inner figure {
    margin: 2.5rem 0;
  }

  .blog-body__inner figure img {
    margin-bottom: 0;
  }

  .blog-body__inner figcaption {
    text-align: center;
    color: #6b7280;
    font-size: 0.875rem;
    font-style: italic;
    margin-top: 0.75rem;
    padding: 0 1rem;
  }

  /* --- Strong / Bold --- */
  .blog-body__inner strong {
    color: #111827;
    font-weight: 700;
  }

  /* --- Emphasis / Italic --- */
  .blog-body__inner em {
    font-style: italic;
  }

  /* --- Strikethrough --- */
  .blog-body__inner s,
  .blog-body__inner del {
    text-decoration: line-through;
    opacity: 0.6;
  }

  /* --- Underline --- */
  .blog-body__inner u {
    text-decoration-color: #16a34a;
    text-underline-offset: 3px;
  }

  /* --- Horizontal rule --- */
  .blog-body__inner hr {
    border: none;
    height: 2px;
    background: linear-gradient(to right, transparent, #dcfce7, #22c55e, #dcfce7, transparent);
    margin: 3rem 0;
  }

  /* ==========================================
     BACK LINK
     ========================================== */
  .blog-back {
    max-width: 48rem;
    margin: 0 auto;
    padding: 2rem 1.5rem 4rem;
  }

  .blog-back__link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: #16a34a;
    font-weight: 600;
    font-size: 1rem;
    padding: 0.75rem 1.5rem;
    background: #f0fdf4;
    border: 1px solid #dcfce7;
    border-radius: 0.75rem;
    transition: all 0.3s ease;
    text-decoration: none;
  }

  .blog-back__link:hover {
    background: #dcfce7;
    color: #15803d;
    transform: translateX(-4px);
    box-shadow: 0 4px 12px rgba(22, 163, 74, 0.1);
  }

  /* ==========================================
     RESPONSIVE
     ========================================== */
  @media (max-width: 640px) {
    .blog-hero--with-image {
      min-height: 40vh;
    }

    .blog-hero__content {
      padding: 2rem 1rem;
    }

    .blog-hero__title {
      font-size: 1.75rem;
    }

    .blog-hero__meta {
      gap: 0.75rem;
    }

    .blog-meta-item {
      font-size: 0.8rem;
    }

    .blog-body {
      padding: 2.5rem 1rem 1.5rem;
    }

    .blog-body__inner h2 {
      font-size: 1.4rem;
    }

    .blog-body__inner h3 {
      font-size: 1.2rem;
    }

    .blog-body__inner p,
    .blog-body__inner ul li,
    .blog-body__inner ol li {
      font-size: 1rem;
    }

    .blog-body__inner blockquote {
      padding: 1.25rem 1.25rem;
    }

    .blog-body__inner img {
      border-radius: 0.75rem;
    }
  }
</style>
