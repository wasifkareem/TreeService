---
import Layout from '../layouts/Layout.astro';
import QuoteForm from '../components/QuoteForm.astro';
import { Image, getImage } from 'astro:assets';
import imgHome from '../assets/imghome.png';
import crane from '../assets/crane.png';
import team from '../assets/team.png';
import treeRemovalImg from '../assets/tree-removal.jpg';
import pruningImg from '../assets/pruning.jpg';
import emergencyImg from '../assets/emergency-service.jpg';

const optimizedHome = await getImage({ src: imgHome, format: 'webp' });
const optimizedCrane = await getImage({ src: crane, format: 'webp' });
const optimizedTeam = await getImage({ src: team, format: 'webp' });
---

<Layout title="Home" description="Expert tree removal, trimming, and emergency services. Serving the community with safe and reliable tree care.">
  <link slot="head" rel="preload" as="image" href={optimizedHome.src} />
  <!-- Hero Section -->
  <section class="relative text-white overflow-hidden min-h-[800px] flex items-center">
    <!-- Dynamic Background Image Gallery -->
    <div class="absolute inset-0 z-0 bg-black">
      <!-- Base image to prevent flash -->
      <img src={optimizedHome.src} alt="Arborist working" width="1920" height="1080" fetchpriority="high" loading="eager" decoding="sync" class="absolute inset-0 w-full h-full object-cover opacity-50" />
      <img src={optimizedHome.src} alt="Arborist working" width="1920" height="1080" fetchpriority="high" loading="lazy" decoding="async" class="absolute inset-0 w-full h-full object-cover animate-bg-slide bg-delay-1" />
      <img src={optimizedCrane.src} alt="Tree removal crane" width="1920" height="1080" loading="lazy" decoding="async" class="absolute inset-0 w-full h-full object-cover animate-bg-slide bg-delay-2" />
      <img src={optimizedTeam.src} alt="Tree care team" width="1920" height="1080" loading="lazy" decoding="async" class="absolute inset-0 w-full h-full object-cover animate-bg-slide bg-delay-3" />
      <div class="absolute inset-0 bg-linear-to-r from-gray-900/90 via-gray-900/50 to-black/20"></div>
    </div>
    
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 lg:py-24 w-full mt-10">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-16 items-center">
        <!-- Left Side: Copy -->
        <div class="flex flex-col items-start text-left">
          <span class="inline-block py-1 px-3 rounded-full bg-primary-500/20 text-primary-400 text-xs font-semibold tracking-wider mb-4 border border-primary-500/30 backdrop-blur-sm animate-fade-in-up">
            24/7 EMERGENCY SERVICE AVAILABLE
          </span>
          <h1 class="text-4xl md:text-5xl xl:text-6xl font-bold tracking-tight mb-4 leading-tight animate-fade-in-up animation-delay-150">
            Expert Tree Care for a <span class="text-primary-400 relative inline-block">
              Safer Landscape
              <svg class="absolute w-full h-2 -bottom-1 left-0 text-primary-500/50" viewBox="0 0 100 10" preserveAspectRatio="none">
                 <path d="M0 5 Q 50 10 100 5" stroke="currentColor" fill="transparent" stroke-width="2"/>
              </svg>
            </span>
          </h1>
          <p class="text-lg text-gray-200 mb-8 animate-fade-in-up animation-delay-300 font-light max-w-lg">
            Professional, fully insured tree removal, pruning, and health care services. Your property's safety is our top priority.
          </p>
          <div class="flex flex-col sm:flex-row gap-3 animate-fade-in-up animation-delay-450 w-full sm:w-auto">
             <a href="/emergency-removal" class="bg-red-600 hover:bg-red-700 text-white px-6 py-3 rounded-full text-base font-semibold transition-all shadow-lg flex items-center justify-center gap-2 transform hover:-translate-y-1 w-full sm:w-auto">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor"><path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z" /></svg>
                Emergency Hotline
             </a>
          </div>
        </div>

        <!-- Right Side: Quote Form -->
        <div class="animate-fade-in-up animation-delay-300 max-w-lg mx-auto lg:ml-auto lg:mr-0 w-full">
          <QuoteForm variant="hero" />
        </div>
      </div>
    </div>
  </section>

  <!-- Services Section -->
  <section class="py-24 bg-gray-50 relative">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-3xl mx-auto mb-16">
        <h2 class="text-primary-700 font-bold tracking-wide uppercase text-sm mb-2">Our Services</h2>
        <h3 class="text-3xl md:text-5xl font-bold text-gray-900 mb-6">Comprehensive Tree Care</h3>
        <p class="text-lg text-gray-600">From precision pruning to complex removals, our certified arborists have the equipment and expertise to handle any job safely.</p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <!-- Service 1 -->
        <div class="bg-white rounded-2xl p-8 border border-gray-100 shadow-sm hover:shadow-xl transition-all duration-300 group flex flex-col transform hover:-translate-y-2 relative overflow-hidden">
          <div class="h-48 -mx-8 -mt-8 mb-6 overflow-hidden">
            <Image src={treeRemovalImg} width="800" height="533" loading="lazy" decoding="async" alt="Tree Removal Service" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" />
            <div class="absolute inset-0 bg-gradient-to-t from-gray-900/60 to-transparent"></div>
          </div>
          <div class="w-16 h-16 bg-primary-100/80 backdrop-blur-sm text-primary-600 rounded-2xl flex items-center justify-center mb-6 shadow-inner absolute top-36 left-8 border border-white/50 z-10">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" /></svg>
          </div>
          <h4 class="text-2xl font-bold text-gray-900 mb-3 mt-4">Tree Removal</h4>
          <p class="text-gray-700 text-lg mb-6 line-clamp-3 leading-relaxed">Safe, efficient removal of dead, diseased, or hazardous trees. We specialize in tight-quarter removals avoiding property damage.</p>
          <a href="/contact-us" class="bg-primary-50 hover:bg-primary-100 text-primary-700 font-bold py-3 px-6 rounded-xl flex items-center justify-center gap-2 transition-colors mt-auto w-full">
            Learn More About Tree Removal <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M12.293 5.293a1 1 0 011.414 0l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-2.293-2.293a1 1 0 010-1.414z" clip-rule="evenodd" /></svg>
          </a>
        </div>

        <!-- Service 2 -->
        <div class="bg-white rounded-2xl p-8 border border-gray-100 shadow-sm hover:shadow-xl transition-all duration-300 group flex flex-col transform hover:-translate-y-2 relative overflow-hidden">
          <div class="h-48 -mx-8 -mt-8 mb-6 overflow-hidden">
            <Image src={pruningImg} width="800" height="533" loading="lazy" decoding="async" alt="Pruning and Trimming Service" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" />
            <div class="absolute inset-0 bg-gradient-to-t from-gray-900/60 to-transparent"></div>
          </div>
          <div class="w-16 h-16 bg-primary-100/80 backdrop-blur-sm text-primary-600 rounded-2xl flex items-center justify-center mb-6 shadow-inner absolute top-36 left-8 border border-white/50 z-10">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.121 14.121L19 19m-7-7l7-7m-7 7l-2.879 2.879M12 12L9.121 9.121m0 5.758a3 3 0 10-4.243-4.243 3 3 0 004.243 4.243z" /></svg>
          </div>
          <h4 class="text-2xl font-bold text-gray-900 mb-3 mt-4">Pruning & Trimming</h4>
          <p class="text-gray-700 text-lg mb-6 line-clamp-3 leading-relaxed">Enhance the health and appearance of your trees with professional pruning. We follow ISA guidelines for optimal tree care.</p>
          <a href="/contact-us" class="bg-primary-50 hover:bg-primary-100 text-primary-700 font-bold py-3 px-6 rounded-xl flex items-center justify-center gap-2 transition-colors mt-auto w-full">
            Learn More About Pruning <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M12.293 5.293a1 1 0 011.414 0l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-2.293-2.293a1 1 0 010-1.414z" clip-rule="evenodd" /></svg>
          </a>
        </div>

        <!-- Service 3 -->
        <div class="bg-white rounded-2xl p-8 border border-red-100 shadow-sm hover:shadow-xl transition-all duration-300 group flex flex-col transform hover:-translate-y-2 relative overflow-hidden">
          <div class="absolute top-0 right-0 bg-red-600 text-white text-xs font-bold px-3 py-1 rounded-bl-lg z-20">24/7 Response</div>
          <div class="h-48 -mx-8 -mt-8 mb-6 overflow-hidden">
            <Image src={emergencyImg} width="800" height="533" loading="lazy" decoding="async" alt="Emergency Service" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" />
            <div class="absolute inset-0 bg-gradient-to-t from-gray-900/60 to-transparent"></div>
          </div>
          <div class="w-16 h-16 bg-red-100/80 backdrop-blur-sm text-red-600 rounded-2xl flex items-center justify-center mb-6 shadow-inner absolute top-36 left-8 border border-white/50 z-10">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>
          </div>
          <h4 class="text-2xl font-bold text-gray-900 mb-3 mt-4">Emergency Care</h4>
          <p class="text-gray-700 text-lg mb-6 line-clamp-3 leading-relaxed">Storm damage? Fallen trees on structures? We provide rapid response 24/7 to secure your property and remove dangerous debris.</p>
          <a href="/emergency-removal" class="bg-red-50 hover:bg-red-100 text-red-700 font-bold py-3 px-6 rounded-xl flex items-center justify-center gap-2 transition-colors mt-auto w-full">
            24/7 Service <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M12.293 5.293a1 1 0 011.414 0l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-2.293-2.293a1 1 0 010-1.414z" clip-rule="evenodd" /></svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-20 bg-primary-900 w-full relative overflow-hidden">
    <div class="absolute inset-0 opacity-10">
      <svg width="100%" height="100%" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <pattern id="smallGrid" width="20" height="20" patternUnits="userSpaceOnUse">
            <path d="M 20 0 L 0 0 0 20" fill="none" stroke="currentColor" stroke-width="0.5"/>
          </pattern>
        </defs>
        <rect width="100%" height="100%" fill="url(#smallGrid)" />
      </svg>
    </div>
    <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center text-white">
      <h2 class="text-4xl font-bold mb-6">Ready to improve your landscape?</h2>
      <p class="text-xl text-primary-100 mb-10 max-w-2xl mx-auto font-light">Get in touch with us today for a free, no-obligation estimate on any of our tree care services.</p>
      <a href="/contact-us" class="inline-block bg-white text-primary-900 font-bold px-10 py-4 rounded-full text-lg hover:bg-primary-50 transition-colors shadow-xl transform hover:-translate-y-1">
        Request Free Estimate
      </a>
    </div>
  </section>
</Layout>

<style>
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .animate-fade-in-up {
    animation: fadeInUp 0.8s ease-out forwards;
    opacity: 0;
  }

  .animation-delay-150 {
    animation-delay: 150ms;
  }
  
  .animation-delay-300 {
    animation-delay: 300ms;
  }

  .animation-delay-450 {
    animation-delay: 450ms;
  }

  @keyframes slideOpacity {
    0% { opacity: 0; transform: scale(1.05); }
    10% { opacity: 1; transform: scale(1); }
    33% { opacity: 1; transform: scale(1); }
    43% { opacity: 0; transform: scale(1.05); }
    100% { opacity: 0; transform: scale(1.05); }
  }

  .animate-bg-slide {
    animation: slideOpacity 18s ease-in-out infinite;
    opacity: 0;
  }
  
  .bg-delay-1 { animation-delay: 0s; }
  .bg-delay-2 { animation-delay: 6s; }
  .bg-delay-3 { animation-delay: 12s; }
</style>
